# ─── Database ────────────────────────────────────────────────────────────────
# DATABASE_URL  — use the pooler connection string for runtime queries (PgBouncer)
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech:5432/nabora?sslmode=require"
# DIRECT_URL — use the direct (non-pooler) hostname for Prisma Migrate DDL
# On Neon: remove "-pooler" from the hostname. On Supabase: add ?pgbouncer=false
DIRECT_URL="postgresql://user:password@host.region.aws.neon.tech/nabora?sslmode=require"

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET="replace-with-a-64-char-random-string"
JWT_EXPIRES_IN="7d"

# ─── Firebase (used when SMS_PROVIDER=firebase) ───────────────────────────────
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@your-project.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Provider Switches ───────────────────────────────────────────────────────
# SMS: firebase | msg91 | twilio | console
SMS_PROVIDER=firebase

# STORAGE: r2 | s3 | local
STORAGE_PROVIDER=local

# MAPS: google | openstreetmap
MAPS_PROVIDER=openstreetmap

# CACHE: redis | memory
CACHE_PROVIDER=memory

# PDF: puppeteer | gotenberg | htmlpdf
PDF_PROVIDER=puppeteer

# EMAIL: console | resend | nodemailer
EMAIL_PROVIDER=console

# PAYMENT: razorpay | phonepe
PAYMENT_PROVIDER=razorpay

# ─── SMS Providers ────────────────────────────────────────────────────────────
MSG91_AUTH_KEY=""
MSG91_TEMPLATE_ID=""
MSG91_SENDER_ID="NABORA"

TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ─── Storage — Cloudflare R2 ─────────────────────────────────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="nabora-uploads"
R2_PUBLIC_URL="https://files.nabora.in"

# ─── Storage — AWS S3 ────────────────────────────────────────────────────────
S3_BUCKET_NAME=""
S3_REGION="ap-south-1"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""

# ─── Maps ─────────────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=""

# ─── Cache — Redis ────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── PDF — Gotenberg ─────────────────────────────────────────────────────────
GOTENBERG_URL="http://localhost:3001"

# ─── App ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL="http://localhost:3001"
